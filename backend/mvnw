#!/bin/sh
# Maven Wrapper script - downloads and runs Maven
# Licensed to the Apache Software Foundation (ASF)

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=java
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

WRAPPER_JAR="$(dirname "$0")/.mvn/wrapper/maven-wrapper.jar"

if [ -r "$WRAPPER_JAR" ]; then
  exec "$JAVACMD" \
    -jar "$WRAPPER_JAR" \
    "$@"
else
  echo "Maven wrapper jar not found. Downloading Maven directly..."
  MAVEN_VERSION="3.9.6"
  MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${MAVEN_VERSION}/apache-maven-${MAVEN_VERSION}-bin.tar.gz"
  
  MAVEN_HOME="$(dirname "$0")/.mvn/maven"
  
  if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven ${MAVEN_VERSION}..."
    mkdir -p "$MAVEN_HOME"
    curl -fsSL "$MAVEN_URL" | tar xzf - -C "$MAVEN_HOME" --strip-components=1
  fi
  
  exec "$MAVEN_HOME/bin/mvn" "$@"
fi
